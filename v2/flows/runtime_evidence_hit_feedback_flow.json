{
  "flowId": "runtime_evidence_hit_feedback_flow",
  "name": "Runtime Evidence Hit Feedback Flow",
  "description": "Verifies a gray-box behavior trigger can change enemy hit-feedback shader evidence in real play_mode.",
  "steps": [
    {
      "id": "launch_game",
      "action": "launchGame"
    },
    {
      "id": "wait_startbutton",
      "action": "wait",
      "until": {
        "hint": "node_exists:StartButton"
      },
      "timeoutMs": 5000
    },
    {
      "id": "click_startbutton",
      "action": "click",
      "target": {
        "hint": "node_name:StartButton"
      }
    },
    {
      "id": "wait_gamelevel",
      "action": "wait",
      "until": {
        "hint": "node_exists:GameLevel"
      },
      "timeoutMs": 5000
    },
    {
      "id": "sample_enemy_hit_count_before",
      "action": "sample",
      "target": {
        "hint": "node_name:Sprite3D"
      },
      "metric": {
        "kind": "shader_param",
        "param_name": "hit_count"
      },
      "windowMs": 80,
      "intervalMs": 40,
      "evidenceKey": "enemy_hit_count_before"
    },
    {
      "id": "check_enemy_hit_count_before_zero",
      "action": "check",
      "checkType": "shader_param_value_seen",
      "evidenceRef": "enemy_hit_count_before",
      "predicate": {
        "operator": "value_seen",
        "value": 0
      }
    },
    {
      "id": "aim_at_enemy",
      "action": "aimAt",
      "player": {
        "hint": "node_name:FPSController"
      },
      "target": {
        "hint": "node_name:Sprite3D"
      }
    },
    {
      "id": "shoot_enemy",
      "action": "shoot",
      "player": {
        "hint": "node_name:FPSController"
      },
      "settleMs": 120
    },
    {
      "id": "sample_enemy_hit_count_after",
      "action": "sample",
      "target": {
        "hint": "node_name:Sprite3D"
      },
      "metric": {
        "kind": "shader_param",
        "param_name": "hit_count"
      },
      "windowMs": 160,
      "intervalMs": 40,
      "evidenceKey": "enemy_hit_count_after"
    },
    {
      "id": "check_enemy_hit_count_after_one",
      "action": "check",
      "checkType": "shader_param_value_seen",
      "evidenceRef": "enemy_hit_count_after",
      "predicate": {
        "operator": "value_seen",
        "value": 1
      }
    },
    {
      "id": "close_project",
      "action": "closeProject"
    }
  ]
}
