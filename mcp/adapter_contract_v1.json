{
  "contract_version": "v1",
  "name": "GodotAdapter Contract",
  "description": "Minimum adapter contract for PointerGPF MCP integration.",
  "transport_modes": [
    {
      "mode": "plugin_adapter",
      "description": "Godot editor/runtime plugin implements adapter API directly."
    },
    {
      "mode": "file_bridge",
      "description": "File-based command/response bridge compatible with command.json/response.json style flows."
    }
  ],
  "required_actions": [
    {
      "id": "launchGame",
      "request_fields": [],
      "response_fields": ["ok", "message"]
    },
    {
      "id": "click",
      "request_fields": ["target"],
      "response_fields": ["ok", "message"]
    },
    {
      "id": "wait",
      "request_fields": ["until", "timeoutMs"],
      "response_fields": ["ok", "elapsedMs", "conditionMet"]
    },
    {
      "id": "check",
      "request_fields": ["kind"],
      "response_fields": ["ok", "details"]
    },
    {
      "id": "snapshot",
      "request_fields": ["name"],
      "response_fields": ["ok", "artifactPath"]
    }
  ],
  "optional_actions": [
    "moveMouse",
    "drag",
    "inputText",
    "openMenu",
    "loadSlot",
    "saveSlot",
    "getState",
    "checkVisualHard",
    "captureUiSnapshot"
  ],
  "check_kind_contract": {
    "visual_hard": {
      "description": "When check.kind=visual_hard, adapter should provide deterministic evidence for UI visual validation.",
      "expected_details_fields": [
        "status",
        "artifactPath",
        "resolution",
        "message"
      ]
    }
  },
  "error_codes": [
    "INVALID_ARGUMENT",
    "TARGET_NOT_FOUND",
    "ACTION_NOT_SUPPORTED",
    "NOT_IN_PLAY_MODE",
    "INPUT_PATH_BLOCKED",
    "TIMEOUT",
    "RUNTIME_EXCEPTION",
    "IO_ERROR"
  ],
  "runtime_requirements": {
    "runtime_mode_required": "play_mode",
    "runtime_entry_allowed": [
      "f5_equivalent",
      "already_running_play_session",
      "unknown"
    ],
    "input_mode": "in_engine_virtual_input",
    "os_input_interference": false,
    "protocol_mode": "three_phase",
    "fail_fast_on_verify": true
  },
  "runtime_bridge": {
    "transport_mode": "file_bridge",
    "command_file_rel": "pointer_gpf/tmp/command.json",
    "response_file_rel": "pointer_gpf/tmp/response.json",
    "required_response_fields": ["ok", "seq", "run_id"],
    "timeout_error_code": "TIMEOUT"
  },
  "chat_protocol": {
    "mode": "three_phase",
    "required_phases": ["started", "result", "verify"]
  },
  "compliance": {
    "minimum_required_actions_count": 5,
    "must_emit_structured_error": true,
    "must_include_action_id_in_failures": true
  }
}
