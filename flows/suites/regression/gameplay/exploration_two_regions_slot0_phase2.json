{
  "flowId": "region_progress_two_regions_slot0_phase2",
  "name": "探索回归 phase2：再次启动后继续游戏，校验存档与内存中的探索结果",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 25,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "steps": [
    {
      "id": "sleep_boot",
      "action": "sleep",
      "ms": 500
    },
    {
      "id": "click_continue",
      "action": "click",
      "target": {
        "testId": "btn_continue"
      }
    },
    {
      "id": "wait_ingame",
      "action": "wait",
      "until": {
        "scene": "game_main"
      },
      "minWaitMs": 200,
      "timeoutMs": 2000
    },
    {
      "id": "set_game_speed_x1_stable",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "verify_save_slot_region_progress_two_regions",
      "action": "verifySaveSlotExploration",
      "slot": 0,
      "mustContainExplored": [
        "area_alpha",
        "area_beta",
        "area_gamma"
      ]
    },
    {
      "id": "verify_runtime_region_progress_after_continue",
      "action": "check",
      "kind": "logic_state",
      "expect": {
        "region_progress_explored_ids": [
          "area_gamma",
          "area_alpha",
          "area_beta"
        ]
      },
      "timeoutMs": 5000
    }
  ]
}
