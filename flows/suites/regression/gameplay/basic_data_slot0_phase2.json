{
  "flowId": "basic_data_slot0_phase2",
  "name": "基础数据测试 phase2：继续游戏、校验两房并采集读档后快照",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "TARGET_A_ID": "target_01",
    "TARGET_B_ID": "target_03"
  },
  "steps": [
    {
      "id": "sleep_boot",
      "action": "sleep",
      "ms": 500
    },
    {
      "id": "click_continue",
      "action": "click",
      "target": {
        "testId": "btn_continue"
      }
    },
    {
      "id": "wait_ingame",
      "action": "wait",
      "until": {
        "scene": "game_main"
      },
      "minWaitMs": 200,
      "timeoutMs": 2000
    },
    {
      "id": "pause_before_verify_window",
      "action": "setGlobalPause",
      "paused": true
    },
    {
      "id": "snapshot_after_continue_risk",
      "action": "getState",
      "keys": [
        "resources",
        "game_total_hours",
        "settlement_clock",
        "resource_ledger"
      ],
      "roomId": "${TARGET_B_ID}"
    },
    {
      "id": "verify_target_a_cleaned",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_A_ID}",
      "expect": {
        "target_clean_status": "cleaned"
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_a_built",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_A_ID}",
      "expect": {
        "build_status": "built"
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_b_cleaned",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_B_ID}",
      "expect": {
        "target_clean_status": "cleaned"
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_b_built",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_B_ID}",
      "expect": {
        "build_status": "built"
      },
      "timeoutMs": 5000
    },
    {
      "id": "snapshot_r3",
      "action": "getState",
      "keys": [
        "resources",
        "game_total_hours"
      ],
      "roomId": "${TARGET_B_ID}"
    },
    {
      "id": "resume_after_verify_window",
      "action": "setGlobalPause",
      "paused": false
    }
  ]
}
