{
  "flowId": "target_detail_capacity_after_build_slot0",
  "name": "房间详情庇护分配：建成后立即查看校验",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "TARGET_A_ID": "target_01",
    "TARGET_A_TEST_ID": "target_node_target_01"
  },
  "steps": [
    {
      "id": "prepare_new_game",
      "action": "runSubflow",
      "file": "../../../fragments/common/new_game_enter_world.json"
    },
    {
      "id": "start_cleanup_mode_target_a",
      "action": "click",
      "target": {
        "testId": "btn_cleanup"
      }
    },
    {
      "id": "select_cleanup_target_a",
      "action": "click",
      "target": {
        "testId": "${TARGET_A_TEST_ID}"
      }
    },
    {
      "id": "confirm_cleanup_target_a",
      "action": "click",
      "target": {
        "testId": "cleanup_confirm_button"
      }
    },
    {
      "id": "wait_clean_done_target_a",
      "action": "wait",
      "until": {
        "stateEquals": {
          "key": "target_clean_status",
          "value": "cleaned",
          "roomId": "${TARGET_A_ID}"
        }
      },
      "timeoutMs": 7000
    },
    {
      "id": "start_build_mode_target_a",
      "action": "click",
      "target": {
        "testId": "btn_build"
      }
    },
    {
      "id": "wait_research_zone_visible_target_a",
      "action": "wait",
      "until": {
        "nodeVisible": {
          "testId": "construction_zone_1"
        }
      },
      "timeoutMs": 5000
    },
    {
      "id": "select_build_zone_target_a",
      "action": "click",
      "target": {
        "testId": "construction_zone_1"
      }
    },
    {
      "id": "select_build_target_a",
      "action": "click",
      "target": {
        "testId": "${TARGET_A_TEST_ID}"
      }
    },
    {
      "id": "wait_build_confirm_visible_target_a",
      "action": "wait",
      "until": {
        "nodeVisible": {
          "testId": "construction_confirm_button"
        }
      },
      "timeoutMs": 5000
    },
    {
      "id": "confirm_build_target_a",
      "action": "click",
      "target": {
        "testId": "construction_confirm_button"
      }
    },
    {
      "id": "wait_build_done_target_a",
      "action": "wait",
      "until": {
        "stateEquals": {
          "key": "build_status",
          "value": "built",
          "roomId": "${TARGET_A_ID}"
        }
      },
      "timeoutMs": 10000
    },
    {
      "id": "click_target_a_open_detail",
      "action": "click",
      "target": {
        "testId": "${TARGET_A_TEST_ID}"
      }
    },
    {
      "id": "wait_target_detail_visible_target_a",
      "action": "wait",
      "until": {
        "nodeVisible": {
          "testId": "target_detail_panel"
        }
      },
      "timeoutMs": 3000
    },
    {
      "id": "verify_target_detail_capacity_after_build_target_a",
      "action": "check",
      "kind": "target_detail_capacity_after_build",
      "expect": {
        "roomId": "${TARGET_A_ID}"
      },
      "timeoutMs": 3000
    },
    {
      "id": "verify_target_detail_capacity_progress_bar_target_a",
      "action": "check",
      "kind": "target_detail_capacity_progress_bar",
      "expect": {
        "roomId": "${TARGET_A_ID}",
        "requireZeroAllocationEmpty": true,
        "ratioTolerance": 0.08
      },
      "timeoutMs": 3000
    }
  ]
}
