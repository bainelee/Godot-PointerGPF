{
  "flowId": "basic_gameplay_slot0_phase2",
  "name": "基础测试流程 phase2：继续游戏并校验两房清理与建设状态",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "TARGET_A_ID": "target_01",
    "TARGET_B_ID": "target_03"
  },
  "steps": [
    {
      "id": "sleep_boot",
      "action": "sleep",
      "ms": 500
    },
    {
      "id": "click_continue",
      "action": "click",
      "target": {
        "testId": "btn_continue"
      }
    },
    {
      "id": "wait_ingame",
      "action": "wait",
      "until": {
        "scene": "game_main"
      },
      "minWaitMs": 200,
      "timeoutMs": 2000
    },
    {
      "id": "set_game_speed_x1_stable",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "verify_target_a_cleaned",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_A_ID}",
      "expect": {
        "target_clean_status": "cleaned"
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_a_built",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_A_ID}",
      "expect": {
        "build_status": "built"
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_b_cleaned",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_B_ID}",
      "expect": {
        "target_clean_status": "cleaned"
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_b_built",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_B_ID}",
      "expect": {
        "build_status": "built"
      },
      "timeoutMs": 5000
    }
  ]
}
