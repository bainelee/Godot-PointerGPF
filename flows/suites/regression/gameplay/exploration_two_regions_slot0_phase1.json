{
  "flowId": "region_progress_two_regions_slot0_phase1",
  "name": "探索回归 phase1：新游戏覆盖存档0，在探索地图界面并行探索两地区，推进时间完成后保存",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 25,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "REGION_A": "area_beta",
    "REGION_B": "area_gamma"
  },
  "steps": [
    {
      "id": "prepare_new_game",
      "action": "runSubflow",
      "file": "../../../fragments/common/new_game_enter_world.json"
    },
    {
      "id": "set_game_speed_x1_before_save",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "click_open_region_progress_map",
      "action": "click",
      "target": {
        "testId": "btn_center"
      }
    },
    {
      "id": "verify_region_progress_overlay_visible",
      "action": "check",
      "kind": "logic_state",
      "expect": {
        "region_progress_overlay_visible": true
      },
      "timeoutMs": 5000
    },
    {
      "id": "explore_region_area_beta",
      "action": "exploreRegion",
      "regionId": "${REGION_A}"
    },
    {
      "id": "explore_region_area_gamma",
      "action": "exploreRegion",
      "regionId": "${REGION_B}"
    },
    {
      "id": "advance_game_hours_complete_parallel_explore",
      "action": "advanceGameHours",
      "hours": 30.0
    },
    {
      "id": "verify_two_regions_explored_before_save",
      "action": "check",
      "kind": "logic_state",
      "expect": {
        "region_progress_explored_ids": [
          "area_gamma",
          "area_alpha",
          "area_beta"
        ]
      },
      "timeoutMs": 5000
    },
    {
      "id": "save_game_slot0",
      "action": "saveGame"
    }
  ]
}
