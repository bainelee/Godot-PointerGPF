{
  "flowId": "explore_one_region_target_slot0_phase2",
  "name": "探索单地区+单房清理建设 phase2：继续游戏，校验存档内探索块与 target_01 清理/建设持久化",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 25,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "TARGET_A_ID": "target_01"
  },
  "steps": [
    {
      "id": "sleep_boot",
      "action": "sleep",
      "ms": 500
    },
    {
      "id": "click_continue",
      "action": "click",
      "target": {
        "testId": "btn_continue"
      }
    },
    {
      "id": "wait_ingame",
      "action": "wait",
      "until": {
        "scene": "game_main"
      },
      "minWaitMs": 200,
      "timeoutMs": 2000
    },
    {
      "id": "set_game_speed_x1_stable",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "verify_save_slot_region_progress_one_region",
      "action": "verifySaveSlotExploration",
      "slot": 0,
      "mustContainExplored": [
        "area_alpha",
        "area_gamma"
      ]
    },
    {
      "id": "verify_runtime_region_progress_one_region_after_continue",
      "action": "check",
      "kind": "logic_state",
      "expect": {
        "region_progress_explored_ids": [
          "area_gamma",
          "area_alpha"
        ]
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_a_cleaned",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_A_ID}",
      "expect": {
        "target_clean_status": "cleaned"
      },
      "timeoutMs": 5000
    },
    {
      "id": "verify_target_a_built",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${TARGET_A_ID}",
      "expect": {
        "build_status": "built"
      },
      "timeoutMs": 5000
    }
  ]
}
